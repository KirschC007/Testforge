# TestForge — Local Development Environment
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# For production (Hetzner/Docker), see .env.hetzner instead.

# ─── Database ──────────────────────────────────────────────────────────────────
# Local: use the Docker Compose MySQL (docker compose up -d db)
DATABASE_URL=mysql://testforge:testforge@localhost:3306/testforge

# ─── Authentication ─────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=dev_jwt_secret_change_in_production

# ─── LLM API ───────────────────────────────────────────────────────────────────
# TestForge uses Google Gemini by default (cheapest, sufficient quality).
# Get a free key: https://aistudio.google.com/app/apikey
LLM_API_KEY=your_gemini_api_key_here
LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Alternative: OpenAI-compatible endpoint
# LLM_API_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...

# ─── Storage (MinIO for local dev, S3 for production) ──────────────────────────
# Local: use the Docker Compose MinIO (docker compose up -d minio)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=testforge
S3_SECRET_KEY=testforge123
S3_BUCKET=testforge
S3_REGION=us-east-1

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Optional: GitHub integration ──────────────────────────────────────────────
# For GitHub URL code scanning — create a Personal Access Token with repo:read scope
# GITHUB_TOKEN=ghp_...

# ─── Optional: Debug / Test Reset ──────────────────────────────────────────────
# Protects POST /api/debug/reset-test-tenant (used by generated E2E tests)
# DEBUG_API_TOKEN=dev_debug_token_change_in_production

# ─── Optional: OAuth (enterprise SSO) ─────────────────────────────────────────
# Only needed if using external OAuth provider instead of built-in auth
# OAUTH_SERVER_URL=https://auth.yourcompany.com
# VITE_OAUTH_PORTAL_URL=https://auth.yourcompany.com/portal
