# TestForge Hetzner Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.hetzner .env

# ─── Database ─────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_PASSWORD=change_me_db_password

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=change_me_jwt_secret_32_chars_minimum

# ─── LLM API (Google Gemini) ──────────────────────────────────────────────────
# IMPORTANT: This is a TEMPLATE file checked into git. NEVER commit a real key here.
# 1. Copy this file to .env on your server (.env is gitignored).
# 2. Put your real key into .env, NOT into this template.
# Get a key: https://aistudio.google.com/app/apikey
LLM_API_KEY=your_gemini_api_key_here
LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/openai

# ─── MinIO S3 Storage ─────────────────────────────────────────────────────────
MINIO_ROOT_USER=testforge
MINIO_ROOT_PASSWORD=change_me_minio_password
S3_BUCKET=testforge
