# TestForge Proof Suite — Environment Variables
# Copy this file to .env and fill in your values

# API base URL (required)
BASE_URL=http://localhost:3000

# Test tenant IDs (required for IDOR tests)
TEST_TENANT_ID=99001
TEST_TENANT_B_ID=99002

# Credentials for each role
null=owner@example.com
null=changeme
null=admin@example.com
null=changeme
null=member@example.com
null=changeme
null=viewer@example.com
null=changeme
null=guest@example.com
null=changeme

# Optional: Debug token for direct DB state checks
DEBUG_API_TOKEN=
