# TestForge Proof Suite — Environment Variables
# Copy this file to .env and fill in your values

# API base URL (required)
BASE_URL=http://localhost:3000

# Test tenant IDs (required for IDOR tests)
TEST_TENANT_ID=99001
TEST_TENANT_B_ID=99002

# Credentials for each role
null=organizer_admin@example.com
null=changeme
null=organizer_staff@example.com
null=changeme
null=attendee@example.com
null=changeme

# Optional: Debug token for direct DB state checks
DEBUG_API_TOKEN=
