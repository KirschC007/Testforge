# TestForge Proof Suite — Environment Variables
# Copy this file to .env and fill in your values

# API base URL (required)
BASE_URL=http://localhost:3000

# Test tenant IDs (required for IDOR tests)
TEST_TENANT_ID=99001
TEST_TENANT_B_ID=99002

# Credentials for each role
TECH_USER=technician@example.com
TECH_PASS=changeme
NURSE_USER=nurse@example.com
NURSE_PASS=changeme
BILLING_USER=billing@example.com
BILLING_PASS=changeme
ADMIN_USER=admin@example.com
ADMIN_PASS=changeme

# Optional: Debug token for direct DB state checks
DEBUG_API_TOKEN=
