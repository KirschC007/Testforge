# TestForge Proof Suite — Environment Variables
# Copy this file to .env and fill in your values

# API base URL (required)
BASE_URL=http://localhost:3000

# Test tenant IDs (required for IDOR tests)
TEST_TENANT_ID=99001
TEST_TENANT_B_ID=99002

# Credentials for each role
E2E_TECHNICIAN_USER=technician@example.com
E2E_TECHNICIAN_PASS=changeme
E2E_NURSE_USER=nurse@example.com
E2E_NURSE_PASS=changeme
E2E_BILLING_USER=billing@example.com
E2E_BILLING_PASS=changeme
E2E_ADMIN_USER=admin@example.com
E2E_ADMIN_PASS=changeme

# Optional: Debug token for direct DB state checks
DEBUG_API_TOKEN=
